<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_university_branding" model="ir.ui.view">
        <field name="name">res.company.form.university.branding</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="University Branding">
                    <group>
                        <group>
                            <field name="university_name"/>
                            <field name="university_tagline"/>
                            <field name="university_code"/>
                        </group>
                        <group>
                            <field name="university_primary_color"/>
                            <field name="university_secondary_color"/>
                            <field name="university_accent_color"/>
                            <field name="gemini_api_key" password="True"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
