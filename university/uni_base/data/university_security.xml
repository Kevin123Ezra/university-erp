<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_university" model="ir.module.category">
        <field name="name">University</field>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_university_role" model="res.groups.privilege">
        <field name="name">Role</field>
        <field name="category_id" ref="uni_base.module_category_university"/>
        <field name="sequence">10</field>
        <field name="placeholder">Select a university role</field>
    </record>

    <record id="group_university_user" model="res.groups">
        <field name="name">University User</field>
        <field name="comment">Base access for university ERP users.</field>
    </record>

    <record id="group_university_student" model="res.groups">
        <field name="name">Student</field>
        <field name="privilege_id" ref="uni_base.privilege_university_role"/>
        <field name="implied_ids" eval="[(4, ref('uni_base.group_university_user'))]"/>
    </record>

    <record id="group_university_faculty" model="res.groups">
        <field name="name">Faculty</field>
        <field name="privilege_id" ref="uni_base.privilege_university_role"/>
        <field name="implied_ids" eval="[(4, ref('uni_base.group_university_user'))]"/>
    </record>

    <record id="group_university_admin" model="res.groups">
        <field name="name">University Admin</field>
        <field name="privilege_id" ref="uni_base.privilege_university_role"/>
        <field name="implied_ids" eval="[(4, ref('uni_base.group_university_user')), (4, ref('base.group_system'))]"/>
    </record>

    <record id="group_university_advisor" model="res.groups">
        <field name="name">Academic Advisor</field>
        <field name="privilege_id" ref="uni_base.privilege_university_role"/>
        <field name="implied_ids" eval="[(4, ref('uni_base.group_university_user'))]"/>
    </record>
</odoo>
