{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Odoo",
            "type": "shell",
            "command": "${config:python.defaultInterpreterPath}",
            "args": [
                "${workspaceFolder}\\odoo-bin",
                "--config=${workspaceFolder}\\odoo.conf",
                "-d",
                "admin"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "servers"
            }
        },
        {
            "label": "Upgrade University Base",
            "type": "shell",
            "command": "${config:python.defaultInterpreterPath}",
            "args": [
                "${workspaceFolder}\\odoo-bin",
                "--config=${workspaceFolder}\\odoo.conf",
                "-d",
                "admin",
                "-u",
                "uni_base",
                "--stop-after-init"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "servers"
            }
        },
        {
            "label": "Start Frontend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}\\university_frontend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "servers"
            }
        },
        {
            "label": "Start All",
            "dependsOn": ["Start Odoo", "Start Frontend"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
